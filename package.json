{
  "name": "clearpage",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check:homepage-design-law": "node scripts/check-homepage-design-law.mjs",
    "check:batch-design-law": "node scripts/check-batch-design-law.mjs",
    "check:document-image-conversion": "node scripts/check-document-image-conversion.mjs",
    "e2e:extract": "node scripts/e2e-extract.mjs",
    "e2e:export": "node scripts/e2e-export.mjs",
    "e2e:feedback": "node scripts/e2e-feedback.mjs",
    "e2e:analytics": "node scripts/e2e-analytics.mjs",
    "e2e:public-metrics": "node scripts/e2e-public-metrics.mjs",
    "e2e:batch": "node scripts/e2e-batch.mjs",
    "e2e:batch-documents": "node scripts/e2e-batch-documents.mjs",
    "e2e:batch-documents-real": "node scripts/e2e-batch-documents-real.mjs",
    "e2e:ui": "node scripts/e2e-ui.mjs",
    "e2e:direct-file": "node scripts/e2e-direct-file.mjs",
    "e2e:full": "npm run e2e:extract && npm run e2e:export && npm run e2e:batch && npm run e2e:batch-documents && npm run e2e:public-metrics && npm run e2e:feedback && npm run e2e:ui && npm run e2e:direct-file && npm run e2e:analytics",
    "e2e:brand-matrix": "node scripts/e2e-brand-matrix.mjs",
    "research:lab:init": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/competitor-lab-bootstrap.ps1",
    "research:lab:sync:direct": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/competitor-lab-sync.ps1 -Cohort direct",
    "research:lab:sync:adjacent": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/competitor-lab-sync.ps1 -Cohort adjacent",
    "research:lab:sync:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/competitor-lab-sync.ps1 -Cohort all",
    "research:lab:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/competitor-lab-status.ps1",
    "research:lab:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/competitor-lab-audit.ps1"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@sparticuz/chromium": "^147.0.2",
    "@vercel/blob": "^2.3.3",
    "better-sqlite3": "^12.9.0",
    "docx": "^9.5.0",
    "isomorphic-dompurify": "^3.9.0",
    "jsdom": "^29.0.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "next": "^16.2.4",
    "pdfjs-dist": "^5.4.296",
    "playwright": "^1.59.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^21.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/turndown": "^5.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.8.0"
  }
}
